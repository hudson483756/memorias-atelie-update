<UserControl x:Class="MemoriasAtelie.TelaVisualizarEncomenda"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Border Background="#FFF9FB" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Button HorizontalAlignment="Left" VerticalAlignment="Center" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnVoltar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B76E79" VerticalAlignment="Center"/>
                            <TextBlock Text=" Voltar para a Lista" FontSize="16" Foreground="#B76E79" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Detalhes da Encomenda" FontSize="22" FontWeight="Bold" Foreground="#2F4F4F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                    <StackPanel>
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" BorderBrush="#FAF5E9" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="CLIENTE" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,3"/>
                                <TextBlock x:Name="TxtCliente" Text="Nome do Cliente" FontSize="20" FontWeight="Bold" Foreground="#2F4F4F" Margin="0,0,0,15"/>

                                <TextBlock Text="PRODUTO" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,3"/>
                                <TextBlock x:Name="TxtProduto" Text="Produto do Ateliê" FontSize="16" Foreground="#4A4A4A" Margin="0,0,0,15"/>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="VALOR DO PEDIDO" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="TxtValor" Text="R$ 0,00" FontSize="18" FontWeight="Bold" Foreground="#B76E79"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,3"/>
                                        <Border x:Name="BorderStatus" Background="#FF9800" CornerRadius="10" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock x:Name="TxtStatus" Text="Pendente" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#FAF5E9" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="OBSERVAÇÕES DO PROJETO" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtObservacoes" Text="Nenhuma observação." FontSize="14" Foreground="#4A4A4A" TextWrapping="Wrap" LineHeight="1.5"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="10,0,0,0" BorderBrush="#FAF5E9" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="GALERIA DE IMAGENS (CLIQUE PARA AMPLIAR)" FontSize="11" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,12" HorizontalAlignment="Center"/>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" VerticalAlignment="Stretch">
                            <ItemsControl x:Name="ListaFotosGerais" VerticalAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>


                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Um Grid para sobrepor o botão de deletar em cima da foto -->
                                        <Grid Margin="0,0,12,0" VerticalAlignment="Stretch">
                                            <!-- Botão da Foto (Clique para Ampliar) -->
                                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="FotoGaleria_Click" VerticalAlignment="Stretch">
                                                <Border Background="#FFFBF6" CornerRadius="8" BorderBrush="#EFEAE0" BorderThickness="1" Width="200" Padding="5" ClipToBounds="True" VerticalAlignment="Stretch">
                                                    <Image Source="{Binding}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Button>

                                            <!-- Botão Excluir (Fica flutuando no canto superior direito) -->
                                            <Button Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5"
                    Background="#FFEAEA" BorderBrush="#FFCCD2" BorderThickness="1" Cursor="Hand"
                    Click="BtnExcluirFoto_Click" ToolTip="Excluir esta foto da encomenda">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="14"/>
                                                        <!-- Deixa o botão redondo -->
                                                    </Style>
                                                </Button.Resources>
                                                <TextBlock Text="❌" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>


                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="TxtAvisoSemFoto" Grid.Row="1" Text="Nenhuma foto anexada" Foreground="#A0A0A0" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>