<UserControl x:Class="MemoriasAtelie.TelaAgendaAnual"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Background="#FFF9FB" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="&#xE112;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" FontSize="18" Cursor="Hand" Foreground="#B76E79" Click="BtnAnoAnterior_Click" Margin="0,0,20,0"/>
                <TextBlock x:Name="TxtAno" Text="2026" FontSize="26" FontWeight="Bold" Foreground="#2F4F4F" Width="100" TextAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="&#xE111;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" FontSize="18" Cursor="Hand" Foreground="#B76E79" Click="BtnProximoAno_Click" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <ItemsControl Grid.Row="1" x:Name="GridMeses">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="3" Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Background="Transparent" BorderThickness="0" Margin="8" Cursor="Hand" Click="CardMes_Click">
                        <Border x:Name="CardBorder" CornerRadius="12" Background="White" BorderBrush="#FAF5E9" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06"/>
                            </Border.Effect>

                            <Border Padding="15">
                                <Grid>
                                    <TextBlock Text="{Binding NomeExtenso}" FontSize="18" FontWeight="SemiBold" Foreground="#2F4F4F" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding TotalEncomendas}" FontSize="14" FontWeight="Bold" Foreground="#B76E79"/>
                                        <TextBlock Text=" entregas" FontSize="11" Foreground="#888888" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Border>
                    </Button>

                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="#FFFBF2"/>
                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="#B76E79"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>