<UserControl x:Class="MemoriasAtelie.TelaDetalhesDia"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Background="#FFF9FB" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnVoltar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B76E79" VerticalAlignment="Center"/>
                        <TextBlock Text=" Voltar para o Mês" FontSize="16" Foreground="#B76E79" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="TxtTituloDia" Text="Entregas do Dia" FontSize="22" FontWeight="Bold" Foreground="#2F4F4F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ListView Grid.Row="1" x:Name="ListaEncomendasDia" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="12" Margin="0,0,0,12" Padding="20" BorderBrush="#FAF5E9" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.04"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">

                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CardEncomenda_Click" HorizontalAlignment="Left" Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B76E79" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding NomeCliente}" FontSize="18" FontWeight="Bold" Foreground="#2F4F4F" VerticalAlignment="Center" TextDecorations="Underline"/>
                                    </StackPanel>
                                </Button>

                                <StackPanel Orientation="Horizontal" Margin="2,3,0,0">
                                    <TextBlock Text="Produto:" FontSize="14" Foreground="#888888"/>
                                    <TextBlock Text="{Binding Produto}" FontSize="14" FontWeight="SemiBold" Foreground="#4A4A4A" Margin="5,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ValorFormatado}" FontSize="18" FontWeight="Bold" Foreground="#B76E79" HorizontalAlignment="Right" Margin="0,0,0,5"/>

                                <Border Background="{Binding CorStatus}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>