<Window x:Class="MemoriasAtelie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MemoriasAtelie"
        mc:Ignorable="d"
        Title="Memórias Ateliê" 
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"    
        WindowStyle="None"                
        AllowsTransparency="True"  
        Closing="Window_Closing"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid Background="Transparent">
        <Image Source="fundo_cristal.gif" Height="650" Stretch="Uniform" />

        <ContentControl x:Name="AreaConteudo" Margin="40,140,40,40" />

        <Border Background="#99FFFFFF" CornerRadius="10" Padding="5,2,5,2" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,20,0" 
                WindowChrome.IsHitTestVisibleInChrome="True">
            <StackPanel Orientation="Horizontal">
                <Button Width="35" Height="30" ToolTip="Minimizar" Click="BtnMinimizar_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <Button Width="35" Height="30" ToolTip="Maximizar" Click="BtnMaximizar_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock x:Name="TxtIconeMaximizar" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <Button Width="35" Height="30" ToolTip="Fechar" Click="BotaoSair_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#CC0000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <Border Background="#CCFFFFFF" CornerRadius="20" Padding="10" Height="60" Width="60" 
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,15,0,0" 
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <Button Width="40" Height="40" ToolTip="Menu de Opções" x:Name="BotaoMenu" Click="BotaoMenu_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.ContextMenu>

                    <ContextMenu x:Name="MenuSuspenso">
                        <MenuItem Header="Cadastro de Cliente" Click="MenuCadastroCliente_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Nova Encomenda" Click="MenuNovaEncomenda_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE116;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Agenda Anual" Click="MenuAgendaAnual_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Relatório de Encomendas" Click="MenuRelatorioEncomendas_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="📊" VerticalAlignment="Center" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Gestão Financeira" Click="MenuGestaoFinanceira_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE10B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Restaurar Backup" Click="MenuRestaurarBackup_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="&#xE149;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="Gerenciar Banco de Dados" Click="MenuGerenciarBanco_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="⚙️" VerticalAlignment="Center" FontSize="14"/>
                            </MenuItem.Icon>
                        </MenuItem>

                        <Separator />

                        <MenuItem Header="Voltar para o Início" Click="MenuInicio_Click"/>
                    </ContextMenu>


                </Button.ContextMenu>
                <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </Border>

        <Grid x:Name="GridZoomGlobal" Visibility="Collapsed" Panel.ZIndex="9999">
            <Border Background="#D9111111" MouseDown="FecharZoomGlobal_Click"/>

            <Border Background="White" CornerRadius="18" Padding="12" MaxWidth="600" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border CornerRadius="10" ClipToBounds="True" Background="#FFFBF9">
                        <Image x:Name="ImgZoomGlobalPreview" Stretch="Uniform" MaxHeight="500"/>
                    </Border>

                    <Button Grid.Row="1" Content="Fechar Visualização" Background="#B76E79" Foreground="White" FontSize="13" FontWeight="SemiBold" Height="35" Margin="0,12,0,0" BorderThickness="0" Cursor="Hand" Click="FecharZoomGlobal_Click"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>