<UserControl x:Class="MemoriasAtelie.TelaAgendaMensal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Background="#FFF9FB" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnVoltar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE112;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B76E79" VerticalAlignment="Center"/>
                        <TextBlock Text=" Voltar para o Ano" FontSize="16" Foreground="#B76E79" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="TxtTituloMesAno" Text="Junho de 2026" FontSize="24" FontWeight="Bold" Foreground="#2F4F4F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GridDiasComEncomenda">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent" BorderThickness="0" Margin="10" Cursor="Hand" Click="CardDia_Click">

                            <Button.ToolTip>
                                <ToolTip Background="#2F4F4F" BorderThickness="0" HasDropShadow="True">
                                    <Border Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Clientes do Dia:" FontWeight="Bold" Foreground="#FFF3DD" FontSize="14" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding ListaClientes}" Foreground="White" FontSize="13" LineHeight="1.4"/>
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </Button.ToolTip>

                            <Border x:Name="DiaBorder" Width="100" Height="100" CornerRadius="15" Background="White" BorderBrush="#FAF5E9" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06"/>
                                </Border.Effect>

                                <Grid>
                                    <TextBlock Text="{Binding Dia}" FontSize="32" FontWeight="Bold" Foreground="#2F4F4F" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <Border Background="#B76E79" CornerRadius="10" MinWidth="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                                        <TextBlock Text="{Binding Quantidade}" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>

                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DiaBorder" Property="Background" Value="#FFFBF2"/>
                                <Setter TargetName="DiaBorder" Property="BorderBrush" Value="#B76E79"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>