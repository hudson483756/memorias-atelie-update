<UserControl x:Class="MemoriasAtelie.TelaCadastroCliente"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="520" d:DesignWidth="500">

    <Border Background="#E6FFFFFF" CornerRadius="25" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Direction="0" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,40,25">
                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="#FF4081" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Cadastro de Cliente" FontSize="24" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Width="350">
                <TextBlock Text="Nome Completo:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtNome" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5"/>

                <TextBlock Text="WhatsApp / Telefone:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtTelefone" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5" MaxLength="15" TextChanged="TxtTelefone_TextChanged"/>

                <TextBlock Text="Medidas e Observações de Tamanho:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtMedidas" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Content="Salvar Cadastro" Width="140" Height="40" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSalvar_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF4081"/>
                            <Style.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Style.Resources>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>