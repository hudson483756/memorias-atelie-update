<UserControl x:Class="MemoriasAtelie.TelaGestaoFinanceira"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024"
             Background="#F9FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestão Financeira e Relatórios" 
                   FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,10,0" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Color="#000" Opacity="0.05" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TOTAL FATURADO" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D"/>

                    <Grid Margin="0,10,0,0">
                        <TextBlock Text="Ano Selecionado:" VerticalAlignment="Center" Foreground="#34495E"/>
                        <TextBlock x:Name="TxtTotalFaturadoAno" Text="R$ 0,00" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,5,0,0">
                        <TextBlock Text="Mês Filtro/Atual:" VerticalAlignment="Center" Foreground="#34495E"/>
                        <TextBlock x:Name="TxtTotalFaturadoMes" Text="R$ 0,00" FontSize="16" FontWeight="SemiBold" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="10,0,10,0" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Color="#000" Opacity="0.05" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <TextBlock Text="TOTAL A RECEBER" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtTotalAReceberGeral" Text="R$ 0,00" FontSize="18" FontWeight="Bold" Foreground="#D35400" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Margin="0,10,0,5" Background="#ECF0F1"/>

                    <TextBlock Text="Meses Pendentes:" FontSize="10" FontWeight="SemiBold" Foreground="#BDC3C7" Margin="0,0,0,5"/>
                    <ScrollViewer MaxHeight="60" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LstAReceberMeses">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <TextBlock Text="{Binding MesAbv}" FontWeight="SemiBold" Foreground="#5D6D7E" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding ValorFormatado}" FontWeight="Medium" Foreground="#E67E22" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="10,0,0,0" Background="#FFF5F5" BorderBrush="#FFC1C1" BorderThickness="1" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Color="#000" Opacity="0.03" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#C0392B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ENTREGUE, NÃO PAGO" FontSize="11" FontWeight="Bold" Foreground="#C0392B"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtTotalAlertaGeral" Text="R$ 0,00" FontSize="18" FontWeight="Bold" Foreground="#C0392B" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Margin="0,10,0,5" Background="#FADBD8"/>

                    <TextBlock Text="Meses com Alerta Crítico:" FontSize="10" FontWeight="SemiBold" Foreground="#E6B0AA" Margin="0,0,0,5"/>
                    <ScrollViewer MaxHeight="60" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LstAlertaMeses">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <TextBlock Text="{Binding MesAbv}" FontWeight="SemiBold" Foreground="#922B21" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding ValorFormatado}" FontWeight="Bold" Foreground="#C0392B" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="12" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Color="#000" Opacity="0.03" ShadowDepth="1"/>
            </Border.Effect>
            <WrapPanel VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Ano:" VerticalAlignment="Center" Foreground="#34495E" Margin="0,0,5,0" FontWeight="Medium"/>
                    <ComboBox x:Name="CboAno" Width="90" Height="28" SelectionChanged="Filtro_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Mês:" VerticalAlignment="Center" Foreground="#34495E" Margin="0,0,5,0" FontWeight="Medium"/>
                    <ComboBox x:Name="CboMes" Width="120" Height="28" SelectionChanged="Filtro_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Situação Pgto:" VerticalAlignment="Center" Foreground="#34495E" Margin="0,0,5,0" FontWeight="Medium"/>
                    <ComboBox x:Name="CboSituacaoPgto" Width="110" Height="28" SelectedIndex="0" SelectionChanged="Filtro_Changed">
                        <ComboBoxItem Content="Todos"/>
                        <ComboBoxItem Content="Pago"/>
                        <ComboBoxItem Content="Parcial"/>
                        <ComboBoxItem Content="Não Pago"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Cliente:" VerticalAlignment="Center" Foreground="#34495E" Margin="0,0,5,0" FontWeight="Medium"/>
                    <ComboBox x:Name="CboBuscarCliente" Width="150" Height="28"
                              DisplayMemberPath="Nome" SelectedValuePath="Nome"
                              SelectionChanged="Filtro_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="Produto:" VerticalAlignment="Center" Foreground="#34495E" Margin="0,0,5,0" FontWeight="Medium"/>
                    <ComboBox x:Name="CboBuscarProduto" Width="150" Height="28"
                              DisplayMemberPath="Nome" SelectedValuePath="Nome"
                              SelectionChanged="Filtro_Changed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                    <TextBlock Text="Status Prod:" VerticalAlignment="Center" Foreground="#34495E" Margin="0,0,5,0" FontWeight="Medium"/>
                    <ComboBox x:Name="CboStatusProdFiltro" Width="120" Height="28" SelectedIndex="0" SelectionChanged="Filtro_Changed">
                        <ComboBoxItem Content="Todos"/>
                        <ComboBoxItem Content="Pendente"/>
                        <ComboBoxItem Content="Em Produção"/>
                        <ComboBoxItem Content="Pronto"/>
                        <ComboBoxItem Content="Concluído"/>
                        <ComboBoxItem Content="Entregue"/>
                    </ComboBox>
                </StackPanel>

            </WrapPanel>
        </Border>

        <Grid Grid.Row="3">
            <DataGrid x:Name="DgFinanceiro" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      Background="White" 
                      BorderBrush="#E2E8F0" 
                      RowHeight="38"
                      GridLinesVisibility="Horizontal" 
                      HorizontalGridLinesBrush="#F1F5F9"
                      HeadersVisibility="Column"
                      SelectionMode="Single">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" IsHitTestVisible="True">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataFormatada}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding NomeCliente}" Width="1.5*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Produto" Binding="{Binding Produto}" Width="1.5*" IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Status Produção" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedValuePath="Content"
                      SelectionChanged="CboStatusProducaoGrid_SelectionChanged"
                      Height="26" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Pendente"/>
                                    <ComboBoxItem Content="Em Produção"/>
                                    <ComboBoxItem Content="Pronto"/>
                                    <ComboBoxItem Content="Entregue"/>
                                    <ComboBoxItem Content="Concluído"/>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Valor Total" Binding="{Binding ValorTotalFormatado}" Width="110" IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Valor Pago (R$)" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ValorPagoInput, Mode=TwoWay, UpdateSourceTrigger=Explicit}" 
                                         LostFocus="TxtValorPagoGrid_LostFocus"
                                         Height="26" VerticalAlignment="Center" Padding="4,2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Situação" Binding="{Binding SituacaoFinanceira}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="Pago">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="Parcial">
                                        <Setter Property="Foreground" Value="#E67E22"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="Não Pago">
                                        <Setter Property="Foreground" Value="#C0392B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>