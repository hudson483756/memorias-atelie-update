<UserControl x:Class="MemoriasAtelie.TelaCadastroEncomenda"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoriasAtelie"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="550">

    <Border Background="#E6FFFFFF" CornerRadius="25" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Direction="0" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid Width="420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="&#xE116;" FontFamily="Segoe MDL2 Assets" FontSize="26" Foreground="#FF4081" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtTituloTela" Text="Nova Encomenda" FontSize="24" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="Both">
                <StackPanel>
                    <TextBlock Text="Cliente:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="CboClientes" Grid.Column="0" Height="35" IsEditable="True" SelectionChanged="CboClientes_SelectionChanged"/>
                        <Button Grid.Column="1" Content="+" Width="35" Height="35" Margin="5,0,0,0" FontWeight="Bold" FontSize="16" Foreground="White" Background="#FF4081" Cursor="Hand" Click="BtnAdicionarClienteRapido_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5"/>
                                        </Style>
                                    </Style.Resources>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <TextBlock Text="WhatsApp do Cliente:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtClienteWhatsapp" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5,0,0,0"/>

                    <TextBlock Text="Medidas do Cliente:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtClienteMedidas" Height="60" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"/>

                    <TextBlock Text="Produto:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CboProdutos" Grid.Column="0" Height="35" IsEditable="True" TextSearch.TextPath="."/>
                        <Button Grid.Column="1" Content="+" Width="35" Height="35" Margin="5,0,0,0" FontWeight="Bold" FontSize="16" Foreground="White" Background="#FF4081" Cursor="Hand" Click="BtnAdicionarProdutoRapido_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5"/>
                                        </Style>
                                    </Style.Resources>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <TextBlock Text="Descrição do Pedido:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtDescricao" Height="80" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="5"/>

                    <TextBlock Text="Valor (R$):" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtValor" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5,0,0,0" TextChanged="TxtValor_TextChanged"/>

                    <TextBlock Text="Status da Encomenda:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CboStatus" Height="35" Margin="0,0,0,15">
                        <ComboBoxItem Content="Pendente" IsSelected="True"/>
                        <ComboBoxItem Content="Em Produção"/>
                        <ComboBoxItem Content="Concluído"/>
                        <ComboBoxItem Content="Entregue"/>
                    </ComboBox>

                    <TextBlock Text="Data da Encomenda:" Margin="0,0,0,5" Foreground="#666666" FontWeight="SemiBold"/>
                    <DatePicker x:Name="DpData" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <Button Content="Anexar Fotos de Referência" Height="35" Background="#F0F0F0" Foreground="#333333" BorderBrush="#CCCCCC" Cursor="Hand" Click="BtnAnexarFotos_Click" Margin="0,0,0,10"/>

                    <Border Background="#F9F9F9" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Fotos Anexadas:" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="IcFotosAnexadas">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,10,0">
                                                <Border CornerRadius="5"  BorderBrush="#E0E0E0" BorderThickness="1">
                                                    <Grid Width="80" Height="80">
                                                        <Image Source="{Binding}" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Salvar Encomenda" Width="150" Height="40" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSalvarEncomenda_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF4081"/>
                            <Style.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Style.Resources>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>